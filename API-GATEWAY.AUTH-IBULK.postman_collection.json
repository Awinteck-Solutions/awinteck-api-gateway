              "raw": "{\n  \"name\": \"MySMTP\",\n  \"type\": \"smtp\",\n  \"fromNameDefault\": \"My Company\",\n  \"fromEmailDefault\": \"no-reply@mycompany.com\",\n  \"replyToEmail\": \"support@mycompany.com\",\n  \"secrets\": {\n    \"host\": \"smtp.mailtrap.io\",\n    \"port\": 587,\n    \"secure\": false,\n    \"username\": \"SMTP_USERNAME\",\n    \"password\": \"SMTP_PASSWORD\"\n  }\n}\n"
            },
            "url": {
              "raw": "{{gatewayBaseUrl}}/ibulk/api/sender-identities",
              "host": ["{{gatewayBaseUrl}}"],
              "path": ["ibulk", "api", "sender-identities"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "try {",
                  "  const json = pm.response.json();",
