{
  "info": {
    "_postman_id": "d6f80f44-36f1-4e49-8c90-5b0013a4f8c1",
    "name": "API Gateway - AUTH + IBULK",
    "description": "Gateway-first Postman collection for API-GATEWAY, AUTH, and IBULK. All requests are routed through API-GATEWAY base URL.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "gatewayBaseUrl", "value": "http://localhost:9000" },
    { "key": "developerId", "value": "dev_demo_001" },
    { "key": "subscriptionTier", "value": "BASIC" },
    { "key": "service", "value": "ibulk" },
    { "key": "apiKey", "value": "" },
    { "key": "accessToken", "value": "" },
    { "key": "templateId", "value": "" },
    { "key": "senderIdentityId", "value": "" },
    { "key": "audienceId", "value": "" },
    { "key": "audienceSnapshotId", "value": "" },
    { "key": "campaignId", "value": "" },
    { "key": "providerMessageId", "value": "" },
    { "key": "unsubscribeToken", "value": "PASTE_TOKEN_HERE" }
  ],
  "item": [
    {
      "name": "API-GATEWAY",
      "item": [
        {
          "name": "GET /health",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{gatewayBaseUrl}}/health",
              "host": ["{{gatewayBaseUrl}}"],
              "path": ["health"]
            }
          }
        }
      ]
    },
    {
      "name": "AUTH (via gateway /auth)",
      "item": [
        {
          "name": "GET /auth/health",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{gatewayBaseUrl}}/auth/health",
              "host": ["{{gatewayBaseUrl}}"],
              "path": ["auth", "health"]
            }
          }
        },
        {
          "name": "POST /auth/api/register",
          "request": {
            "method": "POST",
            "header": [
              { "key": "content-type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"developerId\": \"{{developerId}}\",\n  \"subscriptionTier\": \"{{subscriptionTier}}\",\n  \"service\": \"{{service}}\"\n}\n"
            },
            "url": {
              "raw": "{{gatewayBaseUrl}}/auth/api/register",
              "host": ["{{gatewayBaseUrl}}"],
              "path": ["auth", "api", "register"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "try {",
                  "  const json = pm.response.json();",
                  "  if (json && json.apiKey) pm.collectionVariables.set('apiKey', json.apiKey);",
                  "} catch (e) {}"
                ]
              }
            }
          ]
        },
        {
          "name": "POST /auth/api/token",
          "request": {
            "method": "POST",
            "header": [
              { "key": "content-type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"apiKey\": \"{{apiKey}}\"\n}\n"
            },
            "url": {
              "raw": "{{gatewayBaseUrl}}/auth/api/token",
              "host": ["{{gatewayBaseUrl}}"],
              "path": ["auth", "api", "token"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "try {",
                  "  const json = pm.response.json();",
                  "  if (json && json.accessToken) pm.collectionVariables.set('accessToken', json.accessToken);",
                  "} catch (e) {}"
                ]
              }
            }
          ]
        },
        {
          "name": "POST /auth/api/validate",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": {
              "raw": "{{gatewayBaseUrl}}/auth/api/validate",
              "host": ["{{gatewayBaseUrl}}"],
              "path": ["auth", "api", "validate"]
            }
          }
        }
      ]
    },
    {
      "name": "IBULK (via gateway /ibulk)",
      "auth": {
        "type": "bearer",
        "bearer": [
          { "key": "token", "value": "{{accessToken}}", "type": "string" }
        ]
      },
      "item": [
        {
          "name": "GET /ibulk/health",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{gatewayBaseUrl}}/ibulk/health",
              "host": ["{{gatewayBaseUrl}}"],
              "path": ["ibulk", "health"]
            }
          }
        },
        {
          "name": "GET /ibulk/api",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{gatewayBaseUrl}}/ibulk/api",
              "host": ["{{gatewayBaseUrl}}"],
              "path": ["ibulk", "api"]
            }
          }
        },
        {
          "name": "GET /ibulk/api/templates",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{gatewayBaseUrl}}/ibulk/api/templates?limit=50&withContent=false",
              "host": ["{{gatewayBaseUrl}}"],
              "path": ["ibulk", "api", "templates"],
              "query": [
                { "key": "limit", "value": "50" },
                { "key": "withContent", "value": "false" }
              ]
            }
          }
        },
        {
          "name": "POST /ibulk/api/templates",
          "request": {
            "method": "POST",
            "header": [
              { "key": "content-type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"WelcomeEmail\",\n  \"channel\": \"email\",\n  \"subject\": \"Welcome, {{firstName}}!\",\n  \"body\": \"<h1>Hello {{firstName}}</h1><p>Your code is {{code}}</p>\",\n  \"engine\": \"handlebars\",\n  \"sampleData\": { \"firstName\": \"Sam\", \"code\": \"123456\" }\n}\n"
            },
            "url": {
              "raw": "{{gatewayBaseUrl}}/ibulk/api/templates",
              "host": ["{{gatewayBaseUrl}}"],
              "path": ["ibulk", "api", "templates"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "try {",
                  "  const json = pm.response.json();",
                  "  const id = json?.template?._id || json?.template?.id;",
                  "  if (id) pm.collectionVariables.set('templateId', id);",
                  "} catch (e) {}"
                ]
              }
            }
          ]
        },
        {
          "name": "POST /ibulk/api/templates/:id/preview",
          "request": {
            "method": "POST",
            "header": [
              { "key": "content-type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"data\": { \"firstName\": \"Amina\", \"code\": \"ABC-999\" }\n}\n"
            },
            "url": {
              "raw": "{{gatewayBaseUrl}}/ibulk/api/templates/{{templateId}}/preview",
              "host": ["{{gatewayBaseUrl}}"],
              "path": ["ibulk", "api", "templates", "{{templateId}}", "preview"]
            }
          }
        },
        {
