              "raw": "{\n  \"recipients\": [\n    { \"recipient\": \"user1@example.com\", \"fields\": { \"firstName\": \"User\", \"code\": \"111\" } },\n    { \"recipient\": \"user2@example.com\", \"fields\": { \"firstName\": \"User\", \"code\": \"222\" } }\n  ],\n  \"metadata\": { \"source\": \"postman\" }\n}\n"
            },
            "url": {
